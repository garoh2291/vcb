<?xml version="1.0" encoding="UTF-8"?>
<!-- Template. install_service.sh fills __PYTHON__ and __DIR__ and copies this to
     ~/Library/LaunchAgents/com.garnik.visawatcher.plist -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.garnik.visawatcher</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/caffeinate</string>
    <string>-i</string>
    <string>__PYTHON__</string>
    <string>__DIR__/server.py</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__DIR__</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <!-- Don't hammer-restart if it crashes instantly -->
  <key>ThrottleInterval</key>
  <integer>30</integer>

  <key>StandardOutPath</key>
  <string>__DIR__/bot.log</string>
  <key>StandardErrorPath</key>
  <string>__DIR__/bot.log</string>
</dict>
</plist>
