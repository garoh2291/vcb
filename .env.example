# ---- TLScontact login ----
TLS_LOGIN=your_email@example.com
TLS_PASSWORD=your_password

# ---- Telegram ----
TELEGRAM_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789

# ---- URLs ----
HOME_URL=https://visas-it.tlscontact.com/en-us
# Your real appointment page (the one that 404/redirects on refresh). Fill after first login.
APPOINTMENT_URL=https://visas-it.tlscontact.com/workflow/appointment-booking/amEVN2it/2058661

# ---- Timing (seconds) ----
CHECK_INTERVAL=300
HEARTBEAT_INTERVAL=1800

# ---- Dashboard / behaviour ----
PORT=3025
AUTOSTART=true
MONTHS_TO_CHECK=3

# ---- Browser profile (persistent Chrome session lives here) ----
PROFILE_DIR=./chrome_profile

# ---- Slot detection (tune these from calendar_dump.html after setup) ----
# Comma-separated CSS selectors that match an AVAILABLE / clickable day.
AVAILABLE_SELECTORS=[class*="available"],button.day:not([disabled]):not(.disabled),td.day:not(.disabled):not(.empty):not(.off),.calendar-day.is-available
# Comma-separated CSS selector(s) for the calendar container to screenshot (blank = full page).
CALENDAR_SELECTOR=
# If any of these phrases appear on the page, treat as NO slots (case-insensitive).
NO_SLOT_TEXT=no appointment,no available,aucun rendez,currently no,no slots,not available
